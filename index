<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>✨ 辰光小勇者：SEL 冒險傳說 ✨</title>
    <style>
        /* 定義彩虹動態背景 */
        @keyframes rainbowFlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        :root {
            --gold: #fbc02d; /* 閃亮金 */
            --brown: #fffde7; /* 亮黃色文字，提高對比 */
            --bg-start: #ff00ff;
            --bg-end: #00ffff;
        }

        body {
            font-family: 'Microsoft JhengHei', sans-serif;
            margin: 0;
            padding: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
            /* colorful 的動態漸層背景 */
            background: linear-gradient(-45deg, #ff00ff, #ff8c00, #00ffff, #32cd32);
            background-size: 400% 400%;
            animation: rainbowFlow 10s ease infinite;
            color: #fffde7;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        #game-container {
            width: 100%;
            max-width: 550px;
            background: rgba(255, 255, 255, 0.15); /* 半透明背景 */
            backdrop-filter: blur(10px); /* 磨砂玻璃效果 */
            padding: 30px;
            border: 6px solid var(--gold);
            border-radius: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            box-sizing: border-box;
        }

        h1 {
            color: var(--gold);
            font-size: 40px;
            margin-top: 0;
            text-transform: uppercase;
            letter-spacing: 2px;
            filter: drop-shadow(0 0 8px rgba(251, 192, 45, 0.8)); /* 金色發光 */
        }

        #score-board {
            font-size: 22px;
            color: #ffeb3b;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .gesture-img {
            width: 100%;
            max-width: 450px;
            border-radius: 20px;
            border: 4px solid var(--gold);
            box-shadow: 0 0 20px rgba(251, 192, 45, 0.7);
            margin: 20px 0;
            display: none;
        }

        .active {
            display: inline-block;
            animation: fadeIn 0.8s;
        }

        #story {
            font-size: 26px;
            line-height: 1.6;
            margin: 25px 0;
            background: rgba(255, 255, 255, 0.2);
            padding: 25px;
            border-radius: 15px;
            border-left: 8px solid var(--gold);
            text-align: left;
        }

        #options {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        /* Shining Colorful 霓虹按鈕 */
        .btn {
            padding: 18px 30px;
            margin: 12px;
            font-size: 22px;
            cursor: pointer;
            border-radius: 60px;
            border: none;
            color: white;
            font-weight: bold;
            text-transform: uppercase;
            width: 90%;
            transition: 0.3s;
            position: relative;
            overflow: hidden;
            background: linear-gradient(90deg, #ff00ff, #00ffff);
            box-shadow: 0 4px 15px rgba(255, 0, 255, 0.5);
            text-shadow: 1px 1px 2px rgba(0,0,0,0.7);
        }

        .btn:hover {
            transform: scale(1.05);
            /* 滑鼠滑過時彩虹光暈 */
            box-shadow: 0 0 25px rgba(255, 255, 255, 0.9);
            background: linear-gradient(90deg, #00ffff, #ff00ff);
        }

        #feedback {
            font-size: 30px;
            margin-top: 20px;
            min-height: 36px;
        }

    </style>
</head>
<body>

<div id="box">
    <h1 style="color:var(--gold); filter:drop-shadow(0 0 10px rgba(251,192,45,0.8))">✨ 辰光小勇者 ✨</h1>
    
    <div id="login-ui">
        <p>勇者請報上名來（班級學號）：</p>
        <input type="text" id="sid" placeholder="例如：30105" style="padding:15px; font-size:18px; border-radius:10px; border:2px solid #ddd; width: 70%;">
        <br><br>
        <button class="btn" onclick="startAdventure()" style="background:var(--gold); filter:drop-shadow(0 0 10px var(--gold))">進入童話世界 🚪</button>
    </div>

    <div id="game-ui" style="display:none;">
        <div id="stats" style="display:flex; justify-content:space-around; color:#ffeb3b; font-weight:bold; margin-bottom:10px;">
            <span>進度: <span id="progress">0</span> / 5</span>
            <span>積分: <span id="score">0</span></span>
        </div>
        
        <img id="img-silence" class="gesture-img" src="5G-SILENCE.jpg">
        <img id="img-speak" class="gesture-img" src="5G-TO SAY.jpg">
        <img id="img-eyes" class="gesture-img" src="5G-EYES ON ME.jpg">
        <img id="img-emotion" class="gesture-img" src="5G-EMOTIONS.jpg">

        <div id="story"></div>
        <div id="options"></div>
        <div id="feedback"></div>
    </div>
</div>

<script>
let sid, score = 0, cur = 0, errs = 0, startTime;

const levels = [
    { s: "大家吵成一團了！快舉起你的「大力拳頭」，傳送安靜魔法！", c: 0, img: "img-silence", fail: "💡 提示：試著舉起有力量的『大力拳頭』喔！" },
    { s: "有好主意想分享？請先「變出小天線」，讓老師看見有禮貌的你。", c: 1, img: "img-speak", fail: "💡 提示：舉起食指，代表你有很棒的話想分享喔！" },
    { s: "看這邊！跟我比「兔子眼」，看看誰的眼睛最亮？", c: 2, img: "img-eyes", fail: "💡 提示：用雙手比出可愛的兔子眼看老師喔！" },
    { s: "我不舒服...快教我「放在胸口的手勢」，幫我抓出情緒怪物！", c: 3, img: "img-emotion", fail: "💡 提示：感覺到心跳快快的時候，記得摸摸胸口觀察自己喔！" },
    { s: "吵架了！我們要用「BTT 魔法」修好感情。第一步要平靜自己，點什麼？", c: 3, img: "img-emotion", fail: "💡 提示：BTT 第一步是 Body 平靜，先穩定自己喔！" }
];

const optionText = ["1. 手舉拳頭 (Silence) ✊", "2. 我有話要說 ☝️", "3. Eyes On Me 👀", "4. 我有情緒 (Emotion) ❤️"];

function startAdventure() {
    sid = document.getElementById('sid').value;
    if(!sid) return alert("請輸入學號才能領取勇者勳章！");
    document.getElementById('login-ui').style.display='none';
    document.getElementById('game-ui').style.display='block';
    load();
}

function load() {
    if(cur >= 5) {
        finish();
        return;
    }
    const q = levels[cur];
    document.getElementById('progress').innerText = cur + 1;
    document.getElementById('story').innerText = q.s;
    document.getElementById('feedback').innerText = "";
    
    // 圖片顯示邏輯
    document.querySelectorAll('.gesture-img').forEach(i => i.classList.remove('active'));
    document.getElementById(q.img).classList.add('active');
    
    const optArea = document.getElementById('options');
    optArea.innerHTML = "";
    startTime = new Date();

    optionText.forEach((t, i) => {
        const b = document.createElement('button');
        b.className = 'btn';
        b.innerText = t;
        b.onclick = () => check(i);
        optArea.appendChild(b);
    });
}

function check(i) {
    const q = levels[cur];
    if(i === q.correct) {
        score += 20;
        document.getElementById('score').innerText = score;
        document.getElementById('feedback').style.color = "#4caf50";
        document.getElementById('feedback').innerText = "✅ 🎉 太棒了！魔法成功！";
        // 如果需要串接 Google Sheet 資料，可以這裡執行 saveData()
        setTimeout(() => { cur++; errs=0; load(); }, 1500);
    } else {
        errs++;
        document.getElementById('feedback').style.color = "#e91e63";
        document.getElementById('feedback').innerText = "❌ " + q.fail;
    }
}

function finish() {
    document.getElementById('game-ui').innerHTML = `
        <div style="font-size:60px">🏆</div>
        <h2>冒險達成！你是 SEL 騎士！</h2>
        <p>辰光國小的數據已成功同步。<br>勇者积分：${score}</p>
        <button class="btn" onclick="location.reload()" style="background:var(--gold); filter:drop-shadow(0 0 10px var(--gold))">重新開始 🔄</button>
    `;
}
</script>
</body>
</html>
